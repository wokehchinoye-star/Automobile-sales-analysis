      <column caption='% of Customer Gender' datatype='real' default-format='p0.00%' name='[Calculation_111745600242741248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Customer_Gender])/TOTAL(COUNT([Customer_Gender]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue Per sub Category' datatype='integer' name='[Calculation_168040595523657728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Sub_Category]:SUM([Calculation_718887124430139392])}' />
      </column>
      <column caption='Revenue Category' datatype='string' default-role='measure' default-type='ordinal' name='[Calculation_365917504047833089]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_168040595523657728]&gt;500000 THEN&quot;High Revenue&quot; ELSE&quot;Low Revenue&quot; END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_548313288121610245]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Customer_Age]&lt;=25 THEN &quot;15-25&quot; ELSEIF [Customer_Age]&lt;=35 THEN &quot;26-35&quot; ELSEIF [Customer_Age]&lt;=45 THEN &quot;36-45&quot; ELSEIF [Customer_Age]&lt;=55 THEN&quot;46-55&quot;ELSEIF [Customer_Age]&lt;=65 THEN&quot;56-65&quot;ELSEIF [Customer_Age]&lt;=75 THEN&quot;66-75&quot;ELSE&quot;85+&quot;END' />
      </column>
      <column caption='Revenue' datatype='integer' name='[Calculation_718887124430139392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Unit_Price]*[Order_Quantity]' />
      </column>
      <column caption='Profit Margin' datatype='real' default-format='p0.00%' name='[Calculation_718887124432125953]' role='measure' type='quantitative'>
